# Supabase Configuration
# Get these from your Supabase project dashboard

SUPABASE_URL=https://tubptfkubqjzuwgcezqi.supabase.co
SUPABASE_KEY=YOUR_ANON_KEY_HERE

# Optional: Set to "supabase" to force Supabase, "memory" for in-memory fallback
# Default is "auto" which tries Supabase and falls back to memory if unavailable
DATA_BACKEND=supabase

# Enforce that write actions succeed in Supabase (recommended for multi-device demos)
CLOUD_WRITE_REQUIRED=true
